# Copy to .env and fill in real values. Never commit .env.

# Discord bot token (Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=your-bot-token-here

# Discord user ID of the only user allowed to run /restart.
# Leave blank to disable /restart for everyone.
GOD_USER=your-discord-user-id

# Postgres credentials (used by both the postgres container and the bot)
POSTGRES_USER=miku
POSTGRES_PASSWORD=change-me
POSTGRES_DB=miku
